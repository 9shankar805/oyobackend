{
  "name": "oyo-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install && npm run install:api && npm run install:frontend",
    "install:api": "npm --prefix api install",
    "install:frontend": "npm --prefix frontend install",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "npm --prefix api run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "npm run dev",
    "db:setup": "npm --prefix api run db:generate && npm --prefix api run db:push",
    "db:seed": "npm --prefix api run db:seed",
    "test:connections": "node test-connections.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
