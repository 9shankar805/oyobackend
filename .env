# Environment
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Database - MySQL (Using existing hotelsewa database)
# Update password if needed: mysql://root:your_password@localhost:3306/hotelsewa
DATABASE_URL="mysql://root:@localhost:3306/hotelsewa"

# Auth - CHANGE IN PRODUCTION
JWT_SECRET=dev-secret-change-in-production-use-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Email (for future notifications)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
